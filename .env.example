# ===== Google Sheets (ฐานข้อมูลจริงบน production) =====
# ถ้าไม่ตั้งค่า 3 ตัวนี้ ระบบจะใช้ไฟล์ .data/store.json ในเครื่องแทน (สำหรับ dev/ทดสอบ)
#
# วิธีตั้งค่า:
# 1) สร้าง Google Cloud project → เปิดใช้ Google Sheets API
# 2) สร้าง Service Account → สร้าง JSON key → เอา client_email กับ private_key มาใส่
# 3) สร้าง Google Sheet เปล่า 1 ไฟล์ → กด Share ให้อีเมล Service Account เป็น Editor
# 4) เอา Spreadsheet ID (ส่วนกลางของ URL) มาใส่ GOOGLE_SHEETS_SPREADSHEET_ID
#    ระบบจะสร้างแท็บ Requests/Slots/Actions/Options/Logs + seed ตัวเลือกเริ่มต้นให้อัตโนมัติ
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# วางทั้งก้อนรวม -----BEGIN PRIVATE KEY----- ... โดยใช้ \n แทนการขึ้นบรรทัด (ครอบด้วยเครื่องหมายคำพูด)
GOOGLE_PRIVATE_KEY=""

# ===== รหัสผ่านฝั่งผู้อนุมัติ =====
ADMIN_PASSWORD=krungthai123
# กุญแจเซ็น cookie (ควรตั้งเป็นสตริงสุ่มยาว ๆ บน production)
SESSION_SECRET=

# ===== อีเมลแจ้งเตือน (ไม่บังคับ) — ถ้าไม่ตั้ง จะ log ลง console แทน =====
RESEND_API_KEY=
EMAIL_FROM="Training Request <onboarding@resend.dev>"
APP_URL=http://localhost:3000
